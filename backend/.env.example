APP_NAME="TechOS Flow"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://backend-flow.test
FRONTEND_URL=http://techosflow.test:5173

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_EXPIRATION=480

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
ANEXOS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=smtp.zoho.com
MAIL_PORT=465
MAIL_USERNAME=suporte@techosflow.com.br
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="suporte@techosflow.com.br"
MAIL_FROM_NAME="TechOS Flow"

LARAVEL_PDF_DRIVER=dompdf
LARAVEL_PDF_DOMPDF_REMOTE_ENABLED=false

TECHOS_BACKUP_ENABLED=true
TECHOS_BACKUP_PATH=
TECHOS_BACKUP_RETENTION_DAYS=30
TECHOS_BACKUP_SCHEDULE=02:00
PG_DUMP_PATH=
PG_RESTORE_PATH=

PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_KEEP="7 days"
PULSE_USERNAME=
PULSE_PASSWORD=

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,backend-flow.test,techosflow.test,localhost:5173,127.0.0.1:5173,techosflow.test:5173
